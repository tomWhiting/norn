{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Implementation Brief",
  "description": "A self-contained implementation unit with numbered requirements, acceptance criteria, and traceability links.",
  "type": "object",
  "required": ["id", "cluster", "title", "purpose", "task", "requirements", "boundaries", "verification"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z]+-\\d{3}$",
      "description": "Brief ID: cluster prefix + number (e.g. M-002, D-005, X-003)"
    },
    "cluster": {
      "type": "string",
      "description": "Cluster name (e.g. messaging, diagnostics, exchange)"
    },
    "title": {
      "type": "string",
      "description": "Brief title — what this brief delivers"
    },
    "depends_on": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Brief IDs that must land before this one"
    },
    "blocked_by": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "External blockers (non-brief)"
    },
    "checklist": {
      "type": "array",
      "items": { "type": "string", "pattern": "^C\\d+$" },
      "default": [],
      "description": "Checklist item IDs this brief covers"
    },
    "stories": {
      "type": "array",
      "items": { "type": "string", "pattern": "^S\\d+$" },
      "default": [],
      "description": "User story IDs this brief covers"
    },
    "purpose": {
      "type": "string",
      "description": "Why this brief matters — one paragraph"
    },
    "task": {
      "type": "string",
      "description": "What needs to be done — plain-language description of the work before the formal requirements"
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "spec", "acceptance", "files"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^R\\d+$",
            "description": "Requirement ID, sequential per brief (R1, R2, R3)"
          },
          "title": {
            "type": "string",
            "description": "Short requirement title"
          },
          "spec": {
            "type": "string",
            "description": "EARS-notation specification: WHEN/WHILE/IF + THE SYSTEM SHALL/SHALL NOT"
          },
          "acceptance": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Observable conditions that prove this requirement is done"
          },
          "files": {
            "type": "object",
            "properties": {
              "create": {
                "type": "array",
                "items": { "type": "string" },
                "default": [],
                "description": "Files to create"
              },
              "modify": {
                "type": "array",
                "items": { "type": "string" },
                "default": [],
                "description": "Files to modify"
              },
              "delete": {
                "type": "array",
                "items": { "type": "string" },
                "default": [],
                "description": "Files to delete"
              }
            }
          },
          "checklist": {
            "type": "array",
            "items": { "type": "string", "pattern": "^C\\d+$" },
            "default": [],
            "description": "Checklist items this requirement delivers"
          },
          "stories": {
            "type": "array",
            "items": { "type": "string", "pattern": "^S\\d+$" },
            "default": [],
            "description": "User stories this requirement addresses"
          }
        }
      }
    },
    "boundaries": {
      "type": "array",
      "items": { "type": "string" },
      "description": "SHALL NOT statements — scope protection"
    },
    "verification": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Steps a reviewer should follow to verify the whole brief"
    }
  }
}
